{
  "expo": {
    "name": "StyleBook",
    "slug": "stylebook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#141009"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stylebook.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#141009"
      },
      "package": "com.stylebook.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "873c5242-8cf6-420f-84bc-21855321ea96"
      }
    }
  }
}
